# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# Google Sheets (optional)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Server Configuration
PORT=3000
NODE_ENV=development
# สำหรับ production บน Render ให้ตั้งค่าเป็น URL ของแอปพลิเคชัน
# เช่น https://your-app-name.onrender.com
API_URL=http://localhost:3000

# CORS Configuration (สำหรับ production)
# ALLOWED_ORIGINS=https://your-app-name.onrender.com,http://localhost:3000

# Discord Marketplace Channel
DISCORD_MARKETPLACE_CHANNEL=your_marketplace_channel_id_here